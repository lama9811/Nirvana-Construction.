---
/* Header.astro — sticky cinematic nav with a full-screen mobile menu. */
import { company, nav } from "../data/company";
import Logo from "./Logo.astro";

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? current === "/" : current.startsWith(href);
---

<header data-header class="hdr">
  <div class="hdr__inner">
    <Logo variant="compact" class="hdr__logo" />

    <!-- desktop nav -->
    <nav class="nav" aria-label="Primary">
      {
        nav.map((item, i) => (
          <a
            href={item.href}
            class:list={["nav__link", { "is-active": isActive(item.href) }]}
            aria-current={isActive(item.href) ? "page" : undefined}
          >
            <span class="nav__idx">{String(i + 1).padStart(2, "0")}</span>
            <span class="nav__label">{item.label}</span>
          </a>
        ))
      }
    </nav>

    <div class="hdr__cta">
      <a href={company.phoneHref} class="hdr__phone">{company.phone}</a>
      <a href="/contact/" class="btn-quote">
        <span>Get a Quote</span>
      </a>
      <button data-menu-toggle class="burger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span>
      </button>
    </div>
  </div>

  <!-- full-screen mobile menu -->
  <div data-menu class="menu" aria-hidden="true">
    <div class="menu__grid bg-blueprint"></div>
    <nav class="menu__nav" aria-label="Mobile">
      {
        nav.map((item, i) => (
          <a href={item.href} class:list={["menu__link", { "is-active": isActive(item.href) }]}>
            <span class="menu__idx">{String(i + 1).padStart(2, "0")}</span>
            <span class="menu__word">{item.label}</span>
          </a>
        ))
      }
    </nav>
    <div class="menu__foot">
      <a href={company.phoneHref} class="menu__contact">{company.phone}</a>
      <a href={company.emailHref} class="menu__contact menu__contact--dim">{company.email}</a>
      <p class="label menu__addr">{company.address.full}</p>
    </div>
  </div>
</header>

<style>
  .hdr {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    transition: background-color 0.4s, backdrop-filter 0.4s, border-color 0.4s;
    border-bottom: 1px solid transparent;
  }
  .hdr.is-scrolled {
    background-color: color-mix(in oklab, var(--color-ink) 78%, transparent);
    backdrop-filter: blur(14px) saturate(1.4);
    border-bottom-color: color-mix(in oklab, var(--color-bone) 9%, transparent);
  }

  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    max-width: 96rem;
    margin: 0 auto;
    padding: 1.15rem clamp(1.25rem, 4vw, 3.5rem);
    transition: padding 0.4s var(--ease-out-expo);
  }
  .hdr.is-scrolled .hdr__inner {
    padding-top: 0.7rem;
    padding-bottom: 0.7rem;
  }

  /* logo color tweaks for header context */
  .hdr__logo { flex-shrink: 0; }

  /* desktop nav */
  .nav { display: none; gap: 0.35rem; }
  .nav__link {
    position: relative;
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0.5rem 0.85rem;
    color: var(--color-ash);
    transition: color 0.3s;
  }
  .nav__idx {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-concrete);
    transition: color 0.3s;
  }
  .nav__label {
    font-size: 0.86rem;
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  .nav__link::after {
    content: "";
    position: absolute;
    left: 0.85rem;
    right: 0.85rem;
    bottom: 0.28rem;
    height: 1px;
    background: var(--color-flare);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .nav__link:hover { color: var(--color-bone); }
  .nav__link:hover .nav__idx { color: var(--color-emerald); }
  .nav__link:hover::after { transform: scaleX(1); }
  .nav__link.is-active { color: var(--color-bone); }
  .nav__link.is-active .nav__idx { color: var(--color-emerald); }
  .nav__link.is-active::after { transform: scaleX(1); }

  /* cta cluster */
  .hdr__cta { display: flex; align-items: center; gap: 1.1rem; }
  .hdr__phone {
    display: none;
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.04em;
    color: var(--color-ash);
    transition: color 0.3s;
  }
  .hdr__phone:hover { color: var(--color-bone); }

  .btn-quote {
    display: none;
    position: relative;
    padding: 0.62rem 1.25rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-ink);
    background: var(--color-flare);
    overflow: hidden;
    isolation: isolate;
  }
  .btn-quote span { position: relative; z-index: 1; }
  .btn-quote::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-bone);
    transform: translateY(101%);
    transition: transform 0.45s var(--ease-out-expo);
    z-index: 0;
  }
  .btn-quote:hover::before { transform: translateY(0); }

  /* burger */
  .burger {
    display: grid;
    gap: 6px;
    width: 2.4rem;
    height: 2.4rem;
    place-content: center;
    border: 1px solid color-mix(in oklab, var(--color-bone) 16%, transparent);
  }
  .burger span {
    display: block;
    width: 17px;
    height: 1.6px;
    background: var(--color-bone);
    transition: transform 0.35s var(--ease-out-expo), opacity 0.2s;
  }
  .hdr.is-menu-open .burger span:first-child { transform: translateY(3.8px) rotate(45deg); }
  .hdr.is-menu-open .burger span:last-child { transform: translateY(-3.8px) rotate(-45deg); }

  /* mobile menu */
  .menu {
    position: fixed;
    inset: 0;
    z-index: -1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem clamp(1.5rem, 7vw, 4rem) 2.5rem;
    background: var(--color-ink);
    clip-path: inset(0 0 100% 0);
    transition: clip-path 0.7s var(--ease-in-out-quint);
    pointer-events: none;
  }
  .menu__grid { position: absolute; inset: 0; opacity: 0.5; }
  .hdr.is-menu-open .menu {
    clip-path: inset(0 0 0 0);
    pointer-events: auto;
  }

  .menu__nav { position: relative; display: flex; flex-direction: column; }
  .menu__link {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid color-mix(in oklab, var(--color-bone) 8%, transparent);
    color: var(--color-bone);
    opacity: 0;
    transform: translateY(24px);
  }
  .hdr.is-menu-open .menu__link {
    animation: menu-in 0.6s var(--ease-out-expo) forwards;
  }
  .hdr.is-menu-open .menu__link:nth-child(1) { animation-delay: 0.14s; }
  .hdr.is-menu-open .menu__link:nth-child(2) { animation-delay: 0.20s; }
  .hdr.is-menu-open .menu__link:nth-child(3) { animation-delay: 0.26s; }
  .hdr.is-menu-open .menu__link:nth-child(4) { animation-delay: 0.32s; }
  .hdr.is-menu-open .menu__link:nth-child(5) { animation-delay: 0.38s; }
  @keyframes menu-in {
    to { opacity: 1; transform: none; }
  }
  .menu__idx {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-emerald);
  }
  .menu__word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.4rem, 11vw, 4rem);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .menu__link.is-active .menu__word { color: var(--color-flare); }

  .menu__foot {
    position: relative;
    margin-top: 2.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .menu__contact {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--color-bone);
  }
  .menu__contact--dim { color: var(--color-ash); font-size: 0.82rem; }
  .menu__addr { margin-top: 0.5rem; }

  @media (min-width: 960px) {
    .nav { display: flex; }
    .hdr__phone { display: block; }
    .btn-quote { display: inline-flex; }
    .burger { display: none; }
  }
</style>

<script>
  function setupHeader() {
    const header = document.querySelector<HTMLElement>("[data-header]");
    const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
    if (!header || !toggle) return;

    let open = false;
    const setMenu = (next: boolean) => {
      open = next;
      header.classList.toggle("is-menu-open", open);
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      const lenis = (window as any).__lenis;
      if (open) lenis?.stop();
      else lenis?.start();
      document.body.style.overflow = open ? "hidden" : "";
    };

    toggle.addEventListener("click", () => setMenu(!open));
    header.querySelectorAll("[data-menu] a").forEach((a) =>
      a.addEventListener("click", () => setMenu(false)),
    );
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && open) setMenu(false);
    });
  }

  function onScroll() {
    const header = document.querySelector<HTMLElement>("[data-header]");
    if (header) header.classList.toggle("is-scrolled", window.scrollY > 24);
  }

  window.addEventListener("scroll", onScroll, { passive: true });
  document.addEventListener("astro:page-load", () => {
    setupHeader();
    onScroll();
  });
</script>
