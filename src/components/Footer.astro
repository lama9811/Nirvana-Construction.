---
/* Footer.astro — Stitch-style 4-column footer with brand block, services,
   quick links, and contact. */
import { company } from "../data/company";
---

<footer class="bg-on-background border-t-4 border-secondary">
  <div class="grid grid-cols-1 md:grid-cols-4 gap-gutter w-full px-lg py-xxl max-w-container-max mx-auto">
    <div class="md:col-span-1">
      <picture>
        <source type="image/webp" srcset="/logo.webp 1x, /logo@2x.webp 2x" />
        <img
          src="/logo.png"
          alt="Nirvana Construction"
          width="160"
          height="156"
          class="h-16 w-auto mb-lg bg-surface-container-lowest rounded-sm p-xs"
          loading="lazy"
        />
      </picture>
      <p class="font-body-sm text-body-sm text-surface-variant mb-lg max-w-[28rem]">
        Commercial drywall and metal-stud framing across the Greater Baltimore
        region.
      </p>
      <div class="flex gap-md">
        <a
          href={company.phoneHref}
          class="text-surface hover:text-secondary-fixed transition-colors"
          aria-label="Call"
        >
          <span class="material-symbols-outlined">call</span>
        </a>
        <a
          href={company.emailHref}
          class="text-surface hover:text-secondary-fixed transition-colors"
          aria-label="Email"
        >
          <span class="material-symbols-outlined">mail</span>
        </a>
        <a
          href={company.social.facebook}
          class="text-surface hover:text-secondary-fixed transition-colors"
          aria-label="Facebook"
          target="_blank"
          rel="noopener"
        >
          <span class="material-symbols-outlined">public</span>
        </a>
      </div>
    </div>

    <div>
      <h4 class="font-label-bold text-label-bold uppercase text-surface mb-md">Our Services</h4>
      <ul class="space-y-sm">
        <li>
          <a
            href="/services/"
            class="font-body-sm text-body-sm text-surface-variant hover:text-secondary-fixed transition-colors"
          >
            Metal-Stud Framing
          </a>
        </li>
        <li>
          <a
            href="/services/"
            class="font-body-sm text-body-sm text-surface-variant hover:text-secondary-fixed transition-colors"
          >
            Drywall Hang &amp; Finish
          </a>
        </li>
        <li>
          <a
            href="/services/"
            class="font-body-sm text-body-sm text-surface-variant hover:text-secondary-fixed transition-colors"
          >
            Acoustical Ceilings
          </a>
        </li>
        <li>
          <a
            href="/services/"
            class="font-body-sm text-body-sm text-surface-variant hover:text-secondary-fixed transition-colors"
          >
            Insulation &amp; Soundproofing
          </a>
        </li>
      </ul>
    </div>

    <div>
      <h4 class="font-label-bold text-label-bold uppercase text-surface mb-md">Quick Links</h4>
      <ul class="space-y-sm">
        <li>
          <a
            href="/projects/"
            class="font-body-sm text-body-sm text-surface-variant hover:text-secondary-fixed transition-colors"
          >
            Selected Projects
          </a>
        </li>
        <li>
          <a
            href="/about/"
            class="font-body-sm text-body-sm text-surface-variant hover:text-secondary-fixed transition-colors"
          >
            About the Firm
          </a>
        </li>
        <li>
          <a
            href="/contact/"
            class="font-body-sm text-body-sm text-surface-variant hover:text-secondary-fixed transition-colors"
          >
            Get in Touch
          </a>
        </li>
        <li>
          <span class="font-body-sm text-body-sm text-surface-variant">
            {company.certification.full}
          </span>
        </li>
      </ul>
    </div>

    <div>
      <h4 class="font-label-bold text-label-bold uppercase text-surface mb-md">Contact</h4>
      <ul class="space-y-sm">
        <li>
          <a
            href={company.phoneHref}
            class="font-body-sm text-body-sm text-surface-variant hover:text-secondary-fixed transition-colors"
          >
            {company.phone}
          </a>
        </li>
        <li>
          <a
            href={company.emailHref}
            class="font-body-sm text-body-sm text-surface-variant hover:text-secondary-fixed transition-colors"
          >
            {company.email}
          </a>
        </li>
        <li>
          <span class="font-body-sm text-body-sm text-surface-variant">
            {company.address.full}
          </span>
        </li>
        <li>
          <span class="font-body-sm text-body-sm text-surface-variant">{company.hours}</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="border-t border-outline/20">
    <div class="max-w-container-max mx-auto py-lg px-lg text-center font-body-sm text-body-sm text-surface-variant/60">
      © {new Date().getFullYear()} {company.legalName}. Built to the line.
    </div>
  </div>
</footer>
