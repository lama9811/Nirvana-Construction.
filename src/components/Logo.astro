---
/* Logo.astro — Nirvana Construction wordmark + buildings icon.
   Rebuilt as a clean SVG so it's crisp at any size and themeable
   via design tokens. */
interface Props {
  variant?: "compact" | "stacked" | "icon";
  asLink?: boolean;
  class?: string;
}
const { variant = "compact", asLink = true, class: className = "" } = Astro.props;
const Tag = asLink ? "a" : "div";
const baseProps = asLink ? { href: "/", "aria-label": "Nirvana Construction — home" } : {};
---

<Tag {...baseProps} class:list={["logo", `logo--${variant}`, className]}>
  <svg
    class="logo__icon"
    viewBox="0 0 160 160"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden={asLink ? "true" : "false"}
    role="img"
  >
    <title>Nirvana Construction Inc.</title>

    <!-- buildings cluster, all in emerald -->
    <g class="logo__buildings">
      <rect x="22"  y="108" width="18" height="46" />
      <rect x="44"  y="84"  width="18" height="70" />
      <rect x="66"  y="46"  width="24" height="108" />
      <rect x="94"  y="68"  width="18" height="86" />
      <rect x="116" y="92"  width="18" height="62" />
    </g>

    <!-- a thin highlight rail down the tallest building -->
    <rect class="logo__rail" x="76" y="58" width="4" height="92" />

    <!-- swoosh under the buildings -->
    <path
      class="logo__swoosh"
      d="M10 144 Q 80 184 150 132"
      fill="none"
      stroke-width="9"
      stroke-linecap="round"
    />
  </svg>

  {variant !== "icon" && (
    <div class="logo__words">
      <span class="logo__name">NIRVANA</span>
      <span class="logo__sub">Construction&nbsp;Inc.</span>
    </div>
  )}
</Tag>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-bone);
    text-decoration: none;
  }

  .logo__icon {
    display: block;
    color: var(--color-emerald);
  }

  .logo__buildings rect { fill: currentColor; }
  .logo__rail { fill: color-mix(in oklab, var(--color-ink) 90%, currentColor); }
  .logo__swoosh { stroke: currentColor; }

  .logo__words {
    display: flex;
    flex-direction: column;
    line-height: 1;
  }
  .logo__name {
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-flare);
  }
  .logo__sub {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.32em;
    color: var(--color-emerald);
    margin-top: 0.35rem;
  }

  /* compact — header */
  .logo--compact .logo__icon { width: 2rem; height: 2rem; }
  .logo--compact .logo__name { font-size: 1.15rem; }
  .logo--compact .logo__sub { font-size: 0.5rem; letter-spacing: 0.34em; }

  /* stacked — footer / large brand block */
  .logo--stacked { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
  .logo--stacked .logo__icon { width: 4.5rem; height: 4.5rem; }
  .logo--stacked .logo__name { font-size: 2.4rem; }
  .logo--stacked .logo__sub { font-size: 0.7rem; letter-spacing: 0.3em; margin-top: 0.55rem; }

  /* icon only */
  .logo--icon .logo__icon { width: 3rem; height: 3rem; }

  /* hover: subtle lift + swoosh glow */
  a.logo:hover .logo__icon { transform: translateY(-2px); transition: transform 0.4s var(--ease-out-expo); }
  a.logo:hover .logo__swoosh {
    filter: drop-shadow(0 0 6px color-mix(in oklab, var(--color-emerald) 55%, transparent));
  }
  a.logo .logo__icon { transition: transform 0.4s var(--ease-out-expo); }
  a.logo .logo__swoosh { transition: filter 0.4s; }
</style>
