---
import BaseLayout from "../layouts/BaseLayout.astro";
import { company } from "../data/company";
import { services } from "../data/services";

/* Pluggable endpoint — drop in a Formspree form ID or switch to Netlify
   Forms by setting this value. Until then the form submits in "demo" mode
   and shows the success state without delivering. */
const FORM_ENDPOINT = ""; // e.g. "https://formspree.io/f/xxxxxxxx"
---

<BaseLayout
  title="Contact"
  description="Send a message, ask a question, or call Nirvana Construction directly. Mon–Fri 8–4. Nottingham, MD."
>
  {/* ============ Hero ============ */}
  <section class="relative h-[440px] md:h-[520px] w-full flex items-center overflow-hidden">
    <div class="absolute inset-0" style="height:120%;top:-10%;">
      <img
        data-parallax="0.22"
        class="w-full h-full object-cover object-center"
        src="/images/projects/jobsite-02.webp"
        srcset="/images/projects/jobsite-02-800.webp 800w, /images/projects/jobsite-02.webp 1600w"
        sizes="100vw"
        alt="A commercial Nirvana Construction project under way."
        fetchpriority="high"
      />
    </div>
    <div class="absolute inset-0 bg-on-background/60"></div>
    <div class="relative max-w-container-max mx-auto px-lg w-full">
      <div class="max-w-2xl text-surface">
        <span
          data-reveal
          class="inline-block px-md py-xs bg-secondary text-on-secondary font-label-bold text-label-bold uppercase mb-md"
        >
          Contact
        </span>
        <h1 data-words data-delay="0.1" class="font-headline-xl text-headline-xl mb-md">
          Start a project. Get a callback.
        </h1>
        <p data-reveal class="font-body-lg text-body-lg text-white/85">
          Tell us about the job — scope, schedule, location — and we'll be in
          touch quickly. Or just call.
        </p>
      </div>
    </div>
  </section>

  {/* ============ Body ============ */}
  <section class="py-xxl bg-surface-container-low">
    <div class="max-w-container-max mx-auto px-lg grid grid-cols-1 lg:grid-cols-12 gap-xxl">
      {/* Info column */}
      <aside class="lg:col-span-4 space-y-gutter">
        <div data-reveal>
          <div class="flex items-center gap-sm mb-md">
            <div class="w-12 h-1 bg-secondary"></div>
            <p class="font-label-bold text-label-bold text-secondary uppercase tracking-widest">
              Direct Lines
            </p>
          </div>
          <h2 class="font-headline-lg text-headline-lg text-primary mb-sm">
            Quickest way to reach us.
          </h2>
          <p class="font-body-md text-on-surface-variant">
            Hit the phone or email below — we answer fast during business
            hours.
          </p>
        </div>

        <div
          data-reveal
          data-tilt
          class="bg-surface-container-lowest border border-outline-variant p-xl shadow-sm"
        >
          <p class="font-label-bold text-label-bold uppercase text-on-surface-variant mb-xs">
            Phone
          </p>
          <a
            href={company.phoneHref}
            class="font-headline-md text-headline-md text-primary hover:text-secondary transition-colors block"
          >
            {company.phone}
          </a>
        </div>

        <div
          data-reveal
          data-tilt
          class="bg-surface-container-lowest border border-outline-variant p-xl shadow-sm"
        >
          <p class="font-label-bold text-label-bold uppercase text-on-surface-variant mb-xs">
            Email
          </p>
          <a
            href={company.emailHref}
            class="font-body-lg text-body-lg text-primary hover:text-secondary transition-colors break-all"
          >
            {company.email}
          </a>
        </div>

        <div
          data-reveal
          data-tilt
          class="bg-surface-container-lowest border border-outline-variant p-xl shadow-sm"
        >
          <p class="font-label-bold text-label-bold uppercase text-on-surface-variant mb-xs">
            Office
          </p>
          <p class="font-body-md text-on-surface mb-xs">
            {company.address.street}<br />
            {company.address.city}, {company.address.state} {company.address.zip}
          </p>
          <p class="font-label-bold text-label-bold uppercase text-on-surface-variant">
            {company.hours}
          </p>
        </div>

        <div class="bg-primary text-on-primary p-xl shadow-sm">
          <p class="font-label-bold text-label-bold uppercase text-secondary-fixed mb-xs">
            Certification
          </p>
          <p class="font-headline-md text-headline-md mb-xs">DBE / MBE / SBE</p>
          <p class="font-body-sm text-body-sm opacity-80">
            {company.certification.number}
          </p>
        </div>
      </aside>

      {/* Form column */}
      <div class="lg:col-span-8">
        <div data-reveal>
          <div class="flex items-center gap-sm mb-md">
            <div class="w-12 h-1 bg-primary"></div>
            <p class="font-label-bold text-label-bold text-primary uppercase tracking-widest">
              Send a Message
            </p>
          </div>
          <h2 class="font-headline-lg text-headline-lg text-primary mb-lg">
            Tell us about the job.
          </h2>
        </div>

        <div class="ct-form-wrap relative">
          <form
            class="ct-form bg-surface-container-lowest border border-outline-variant p-xl shadow-sm"
            data-form
            action={FORM_ENDPOINT || "#"}
            method="POST"
            novalidate
          >
            <input
              type="text"
              name="website"
              tabindex="-1"
              autocomplete="off"
              class="ct-honey"
              aria-hidden="true"
            />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-lg">
              <label class="field block">
                <span class="font-label-bold text-label-bold uppercase text-on-surface-variant mb-xs block">
                  Name *
                </span>
                <input
                  type="text"
                  name="name"
                  required
                  autocomplete="name"
                  class="w-full border border-outline-variant p-sm font-body-md bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                />
                <span class="err font-label-bold text-label-bold uppercase text-secondary mt-xs hidden">
                  Please enter your name
                </span>
              </label>

              <label class="field block">
                <span class="font-label-bold text-label-bold uppercase text-on-surface-variant mb-xs block">
                  Company
                </span>
                <input
                  type="text"
                  name="company"
                  autocomplete="organization"
                  class="w-full border border-outline-variant p-sm font-body-md bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                />
              </label>

              <label class="field block">
                <span class="font-label-bold text-label-bold uppercase text-on-surface-variant mb-xs block">
                  Email *
                </span>
                <input
                  type="email"
                  name="email"
                  required
                  autocomplete="email"
                  class="w-full border border-outline-variant p-sm font-body-md bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                />
                <span class="err font-label-bold text-label-bold uppercase text-secondary mt-xs hidden">
                  Please enter a valid email
                </span>
              </label>

              <label class="field block">
                <span class="font-label-bold text-label-bold uppercase text-on-surface-variant mb-xs block">
                  Phone
                </span>
                <input
                  type="tel"
                  name="phone"
                  autocomplete="tel"
                  class="w-full border border-outline-variant p-sm font-body-md bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                />
              </label>

              <label class="field block sm:col-span-2">
                <span class="font-label-bold text-label-bold uppercase text-on-surface-variant mb-xs block">
                  Project Type
                </span>
                <select
                  name="project_type"
                  class="w-full border border-outline-variant p-sm font-body-md bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors"
                >
                  <option value="">Select a sector</option>
                  {services.map((s) => <option value={s.title}>{s.title}</option>)}
                  <option value="Other">Other / Multiple</option>
                </select>
              </label>

              <label class="field block sm:col-span-2">
                <span class="font-label-bold text-label-bold uppercase text-on-surface-variant mb-xs block">
                  Project Details *
                </span>
                <textarea
                  name="message"
                  rows="5"
                  required
                  placeholder="Scope, location, schedule, anything relevant…"
                  class="w-full border border-outline-variant p-sm font-body-md bg-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-colors resize-y min-h-[8rem] leading-relaxed"
                ></textarea>
                <span class="err font-label-bold text-label-bold uppercase text-secondary mt-xs hidden">
                  Please add a few details
                </span>
              </label>
            </div>

            <div class="mt-xl flex flex-col sm:flex-row items-start sm:items-center gap-lg sm:justify-between">
              <button
                data-magnetic
                type="submit"
                class="bg-secondary-container text-on-primary px-xl py-md font-button text-button uppercase rounded inline-flex items-center justify-center gap-sm transition-all hover:bg-secondary shadow-lg active:scale-95"
              >
                Send Message
                <span class="material-symbols-outlined">arrow_forward</span>
              </button>
              <p class="font-label-bold text-label-bold uppercase text-on-surface-variant">
                No spam. Replies within 1 business day.
              </p>
            </div>
          </form>

          {/* Success state */}
          <div
            class="ct-success absolute inset-0 bg-surface-container-lowest border border-outline-variant p-xl flex flex-col justify-center opacity-0 pointer-events-none translate-y-md transition-all duration-500 ease-out"
            data-success
            aria-live="polite"
          >
            <span class="material-symbols-outlined text-primary mb-md" style="font-size:56px;">
              check_circle
            </span>
            <h3 class="font-headline-lg text-headline-lg text-primary mb-md">
              Request received.
            </h3>
            <p class="font-body-md text-on-surface-variant max-w-[32rem]">
              Thanks — we'll be in touch shortly. Need it faster?{" "}
              <a
                href={company.phoneHref}
                class="text-secondary underline decoration-secondary hover:text-secondary-container"
              >
                Call {company.phone}
              </a>.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .ct-honey {
    position: absolute !important;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }
  .field.has-error .err { display: block; }
  .field.has-error input,
  .field.has-error textarea,
  .field.has-error select {
    border-color: var(--color-secondary);
  }
  .ct-form-wrap.is-sent .ct-form {
    opacity: 0;
    transform: translateY(-12px);
    pointer-events: none;
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .ct-form-wrap.is-sent .ct-success {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
</style>

<script define:vars={{ endpoint: FORM_ENDPOINT }}>
  function setupForm() {
    const form = document.querySelector("[data-form]");
    const wrap = form?.closest(".ct-form-wrap");
    if (!form || !wrap) return;

    const showError = (field, on) => field.classList.toggle("has-error", on);

    const validate = () => {
      let ok = true;
      form.querySelectorAll(".field").forEach((f) => {
        const input = f.querySelector("input, textarea, select");
        if (!input || !input.required) return showError(f, false);
        const val = String(input.value || "").trim();
        let bad = !val;
        if (!bad && input.type === "email") {
          bad = !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(val);
        }
        showError(f, bad);
        if (bad) ok = false;
      });
      return ok;
    };

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      // honeypot — silently succeed
      const hp = form.querySelector("[name=website]");
      if (hp && hp.value) {
        wrap.classList.add("is-sent");
        return;
      }
      if (!validate()) return;

      const submit = form.querySelector("button[type=submit]");
      submit?.setAttribute("disabled", "");

      try {
        if (endpoint) {
          const fd = new FormData(form);
          const res = await fetch(endpoint, {
            method: "POST",
            body: fd,
            headers: { Accept: "application/json" },
          });
          if (!res.ok) throw new Error("HTTP " + res.status);
        } else {
          // demo mode — placeholder endpoint not configured yet
          await new Promise((r) => setTimeout(r, 700));
        }
        wrap.classList.add("is-sent");
      } catch (err) {
        submit?.removeAttribute("disabled");
        alert("Sorry — something went wrong. Please call +1 (410) 650-9850.");
      }
    });
  }
  setupForm();
  document.addEventListener("astro:page-load", setupForm);
</script>
