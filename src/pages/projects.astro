---
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects, projectCategories } from "../data/projects";

/* Pair photo slugs (or null → placeholder type-card) and lowercase category
   keys for the JS filter. */
const cardData = projects.map((p) => ({
  ...p,
  filter: p.category.toLowerCase(),
}));
---

<BaseLayout
  title="Projects"
  description="Selected commercial projects framed and finished by Nirvana Construction across Maryland — ALDI, Chipotle, DaVita, Golf Galaxy, JCC, MACE Medical and more."
>
  <main class="blueprint-bg min-h-screen">
    {/* ============ Hero ============ */}
    <header class="max-w-container-max mx-auto px-lg py-xxl">
      <div class="border-l-4 border-secondary pl-lg">
        <p data-reveal class="font-label-bold text-label-bold text-secondary uppercase tracking-widest mb-sm">
          Structural Integrity &amp; Precision
        </p>
        <h1 data-words class="font-headline-xl text-headline-xl text-primary max-w-3xl">
          Selected Projects
        </h1>
        <p data-reveal class="font-body-lg text-body-lg text-on-surface-variant mt-md max-w-2xl">
          Commercial drywall and framing delivered across Maryland — retail,
          medical, education, community, and office interiors, built to the
          line and finished on time.
        </p>
      </div>
    </header>

    {/* ============ Filter ============ */}
    <section class="max-w-container-max mx-auto px-lg mb-xl">
      <div class="flex flex-wrap gap-md items-center">
        <span class="font-label-bold text-label-bold text-on-surface-variant uppercase mr-sm">
          Filter Projects:
        </span>
        <button
          class="filter-btn active px-lg py-sm font-button text-button uppercase border-2 border-primary bg-primary text-on-primary transition-all duration-200"
          data-filter="all"
        >
          All
        </button>
        {projectCategories.map((cat) => (
          <button
            class="filter-btn px-lg py-sm font-button text-button uppercase border-2 border-outline-variant text-on-surface-variant hover:border-primary hover:text-primary transition-all duration-200"
            data-filter={cat.toLowerCase()}
          >
            {cat}
          </button>
        ))}
      </div>
    </section>

    {/* ============ Project grid ============ */}
    <section class="max-w-container-max mx-auto px-lg pb-xxl">
      <div id="project-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-gutter">
        {cardData.map((p, i) => (
          <article
            data-reveal
            data-tilt
            class:list={[
              "project-card group bg-surface-container-lowest border border-outline-variant overflow-hidden shadow-sm hover:shadow-2xl transition-shadow duration-300",
              i === 1 && "border-t-4 border-t-secondary",
            ]}
            data-category={p.filter}
          >
            <div class="relative overflow-hidden h-64">
              {p.photo ? (
                <img
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
                  src={`/images/projects/${p.photo}.webp`}
                  srcset={`/images/projects/${p.photo}-800.webp 800w, /images/projects/${p.photo}.webp 1600w`}
                  sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
                  alt={`${p.name} — ${p.location}`}
                  loading="lazy"
                />
              ) : (
                <div class="w-full h-full bg-surface-container-high flex items-center justify-center blueprint-bg">
                  <div class="text-center">
                    <span class="material-symbols-outlined text-on-surface-variant" style="font-size: 56px;">
                      apartment
                    </span>
                    <p class="mt-sm font-label-bold text-label-bold uppercase text-on-surface-variant">
                      {p.category}
                    </p>
                  </div>
                </div>
              )}
              <div class="absolute top-0 right-0 bg-secondary text-on-primary px-md py-xs font-label-bold text-label-bold uppercase">
                {p.category}
              </div>
            </div>
            <div class="p-lg">
              <h3 class="font-headline-md text-headline-md text-primary mb-xs">{p.name}</h3>
              <div class="flex items-center gap-xs text-on-surface-variant font-body-sm">
                <span class="material-symbols-outlined" style="font-size: 18px;">location_on</span>
                <span>{p.location}</span>
              </div>
              <p class="mt-sm font-body-sm text-body-sm text-on-surface-variant">{p.descriptor}</p>
              <div class="mt-md pt-md border-t border-outline-variant flex justify-between items-center">
                <span class="font-label-bold text-label-bold text-primary uppercase">View Details</span>
                <span class="material-symbols-outlined text-secondary">arrow_forward</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    {/* ============ CTA ============ */}
    <section class="bg-primary text-on-primary py-xxl">
      <div class="max-w-container-max mx-auto px-lg text-center">
        <h2 class="font-headline-lg text-headline-lg mb-md">Have a project on the boards?</h2>
        <p class="font-body-lg text-body-lg text-on-primary-container max-w-[36rem] mx-auto mb-xl">
          Send drawings, a few notes about the scope, and a target start date —
          we'll be in touch.
        </p>
        <div class="flex flex-col md:flex-row justify-center items-center gap-lg">
          <a
            data-magnetic
            href="/contact/"
            class="inline-flex items-center gap-sm bg-secondary text-on-primary px-xxl py-md font-button text-button uppercase hover:bg-secondary-container transition-all shadow-lg"
          >
            <span class="material-symbols-outlined">mail</span>
            Get in Touch
          </a>
          <a
            href="/services/"
            class="inline-flex items-center gap-sm border-2 border-on-primary text-on-primary px-xxl py-md font-button text-button uppercase hover:bg-on-primary hover:text-primary transition-all"
          >
            View Services
          </a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  function setupFilter() {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const projectCards = document.querySelectorAll<HTMLElement>(".project-card");
    if (!filterBtns.length) return;

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const f = btn.getAttribute("data-filter") || "all";

        filterBtns.forEach((b) => {
          b.classList.remove("active", "bg-primary", "text-on-primary", "border-primary");
          b.classList.add("border-outline-variant", "text-on-surface-variant");
        });
        btn.classList.remove("border-outline-variant", "text-on-surface-variant");
        btn.classList.add("active", "bg-primary", "text-on-primary", "border-primary");

        projectCards.forEach((card) => {
          const match = f === "all" || card.getAttribute("data-category") === f;
          card.style.transition = "opacity 0.3s ease";
          if (match) {
            card.style.display = "block";
            requestAnimationFrame(() => (card.style.opacity = "1"));
          } else {
            card.style.opacity = "0";
            setTimeout(() => (card.style.display = "none"), 300);
          }
        });
      });
    });
  }
  setupFilter();
  document.addEventListener("astro:page-load", setupFilter);
</script>
