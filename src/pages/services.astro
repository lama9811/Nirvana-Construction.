---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import HeroMotif from "../components/HeroMotif.astro";
import CTASection from "../components/CTASection.astro";
import { services, scopeOfWork } from "../data/services";
---

<BaseLayout
  title="Services"
  description="Commercial drywall and metal-stud framing across six sectors — retail, hospitality, medical, education, office and renovation."
>
  <Hero
    index="Page 03 / 05"
    meta="Six sectors · One trade"
    eyebrow="Services"
    title={`Drywall &amp; framing.<br /><em>Six commercial sectors.</em>`}
    lead="We frame and finish commercial interiors across retail, hospitality, medical, education, office and renovation work — all built on the same trade discipline."
  >
    <HeroMotif slot="visual" section="Services · S-01" coords="6 · Sectors" />
  </Hero>

  <!-- ============= SERVICES LIST ============= -->
  <section class="svc-list">
    <div class="svc-list__inner">
      {
        services.map((s, i) => (
          <article id={s.slug} class="svc-row" data-reveal>
            <div class="svc-row__head">
              <span class="label svc-row__idx">{s.index}</span>
              <div class="svc-row__bar"></div>
            </div>
            <h2 class="svc-row__title">{s.title}</h2>
            <div class="svc-row__detail">
              <p>{s.detail}</p>
              {i === 0 && (
                <p class="svc-row__note label">
                  Each sector built on the shared scope of work below.
                </p>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ============= SCOPE BAND ============= -->
  <section class="svc-scope">
    <div class="svc-scope__inner">
      <header class="svc-scope__head" data-reveal>
        <p class="label svc-scope__eyebrow">
          <span class="svc-scope__bar"></span>The full scope
        </p>
        <h2 class="text-section">
          Every assembly,<br />every finish.
        </h2>
        <p class="svc-scope__lead">
          The trade capabilities we deliver inside each of the sectors above.
        </p>
      </header>
      <ul class="svc-scope__grid">
        {scopeOfWork.map((item, i) => (
          <li class="svc-scope__cell" data-reveal style={`transition-delay:${i * 40}ms`}>
            <span class="label svc-scope__num">{String(i + 1).padStart(2, "0")}</span>
            <span class="svc-scope__name">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTASection title="Need this scope on your next build? Let's talk." />
</BaseLayout>

<style>
  /* SERVICES LIST */
  .svc-list { padding: clamp(3rem, 7vw, 7rem) clamp(1.25rem, 4vw, 3.5rem); }
  .svc-list__inner { max-width: 96rem; margin: 0 auto; }
  .svc-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding: clamp(2.5rem, 5vw, 4rem) 0;
    border-bottom: 1px solid color-mix(in oklab, var(--color-bone) 9%, transparent);
  }
  .svc-row:first-child { border-top: 1px solid color-mix(in oklab, var(--color-bone) 9%, transparent); }
  .svc-row__head { display: flex; align-items: center; gap: 1rem; }
  .svc-row__idx { color: var(--color-emerald); }
  .svc-row__bar {
    flex: 1;
    height: 1px;
    background: color-mix(in oklab, var(--color-bone) 12%, transparent);
  }
  .svc-row__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.25rem, 6vw, 5rem);
    line-height: 0.96;
    letter-spacing: -0.025em;
    text-wrap: balance;
  }
  .svc-row__detail p {
    color: var(--color-ash);
    line-height: 1.65;
    max-width: 36rem;
  }
  .svc-row__note { margin-top: 0.8rem; color: var(--color-flare); }
  @media (min-width: 900px) {
    .svc-row {
      grid-template-columns: 6rem 1fr 1fr;
      gap: 3rem;
      align-items: baseline;
    }
    .svc-row__head { display: contents; }
    .svc-row__bar { display: none; }
    .svc-row__idx { padding-top: 0.4rem; }
  }

  /* SCOPE */
  .svc-scope {
    padding: clamp(4rem, 8vw, 7rem) clamp(1.25rem, 4vw, 3.5rem);
    background: var(--color-graphite);
  }
  .svc-scope__inner { max-width: 96rem; margin: 0 auto; }
  .svc-scope__head { display: grid; gap: 1.25rem; max-width: 44rem; margin-bottom: 3.5rem; }
  .svc-scope__bar {
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: var(--color-emerald);
    margin-right: 0.7rem;
    vertical-align: middle;
  }
  .svc-scope__eyebrow { color: var(--color-emerald); }
  .svc-scope__lead { color: var(--color-ash); }

  .svc-scope__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .svc-scope__cell {
    display: grid;
    grid-template-columns: 4ch 1fr;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1rem 0;
    border-bottom: 1px solid color-mix(in oklab, var(--color-bone) 9%, transparent);
    transition: padding-left 0.4s var(--ease-out-expo), color 0.3s;
  }
  .svc-scope__cell:hover { padding-left: 0.8rem; color: var(--color-flare); }
  .svc-scope__num { color: var(--color-concrete); }
  .svc-scope__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.15rem, 2.4vw, 1.65rem);
  }
  @media (min-width: 780px) {
    .svc-scope__grid { grid-template-columns: 1fr 1fr; column-gap: 4rem; }
  }
</style>
