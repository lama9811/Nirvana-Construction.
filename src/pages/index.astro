---
import BaseLayout from "../layouts/BaseLayout.astro";
import StructureScene from "../components/three/StructureScene.tsx";
import StatBand from "../components/StatBand.astro";
import ServiceCard from "../components/ServiceCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import CTASection from "../components/CTASection.astro";
import Reveal from "../components/Reveal.astro";
import { services, scopeOfWork } from "../data/services";
import { projects } from "../data/projects";
import { company } from "../data/company";

const texturePaths = [
  "/images/textures/jobsite-02.webp",
  "/images/textures/golf-galaxy.webp",
  "/images/textures/jobsite-06.webp",
  "/images/textures/jcc.webp",
  "/images/textures/jobsite-08.webp",
  "/images/textures/mace-medical.webp",
  "/images/textures/jobsite-07.webp",
];

const featured = projects.filter((p) => p.photo).slice(0, 4);
---

<BaseLayout
  title="Home"
  description="Nirvana Construction Inc. — commercial drywall and metal-stud framing subcontractor serving Maryland and the Greater Baltimore region. DBE / MBE / SBE certified."
>
  <!-- =============== H E R O =============== -->
  <section class="home-hero">
    <div class="home-hero__poster" aria-hidden="true">
      <img
        src="/images/projects/jobsite-08.webp"
        srcset="/images/projects/jobsite-08-800.webp 800w, /images/projects/jobsite-08.webp 1600w"
        sizes="100vw"
        width="1600"
        height="1067"
        alt=""
        fetchpriority="high"
      />
    </div>

    <div class="home-hero__canvas">
      <StructureScene client:visible texturePaths={texturePaths} />
    </div>

    <div class="home-hero__veil" aria-hidden="true"></div>

    <div class="home-hero__inner">
      <header class="home-hero__topbar">
        <p class="label home-hero__cert">
          <span class="home-hero__dot"></span>
          {company.certification.label}
        </p>
        <p class="label home-hero__coord">
          N&nbsp;39.371° &nbsp;·&nbsp; W&nbsp;76.476°
          <br />
          Nottingham, MD
        </p>
      </header>

      <div class="home-hero__copy">
        <h1 class="home-hero__title">
          <span class="home-hero__line" style="--d:0ms">Commercial drywall</span>
          <span class="home-hero__line home-hero__line--em" style="--d:120ms">&amp; metal-stud framing,</span>
          <span class="home-hero__line home-hero__line--stroke" style="--d:240ms">built to the line.</span>
        </h1>
        <p class="home-hero__lead" data-reveal>
          A commercial drywall &amp; framing subcontractor serving the Greater
          Baltimore region — framing and finishing retail, hospitality, medical,
          school and office interiors on schedule and ready for inspection.
        </p>
        <div class="home-hero__ctas" data-reveal>
          <a href="/contact/" class="home-hero__primary">
            Request a quote
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M5 19L19 5M19 5H8M19 5v11" stroke="currentColor" stroke-width="2" />
            </svg>
          </a>
          <a href="/projects/" class="home-hero__secondary">See the work</a>
        </div>
      </div>

      <footer class="home-hero__bottombar">
        <div class="home-hero__strip">
          <span class="label">Projects&nbsp;<b>10</b></span>
          <span class="label">Sectors&nbsp;<b>06</b></span>
          <span class="label">Cert&nbsp;<b>22-204</b></span>
        </div>
        <div class="home-hero__scroll">
          <span class="label">Scroll</span>
          <span class="home-hero__scroll-line"></span>
        </div>
      </footer>
    </div>
  </section>

  <!-- =============== S T A T S =============== -->
  <StatBand />

  <!-- =============== S E R V I C E S =============== -->
  <section class="home-services">
    <div class="home-services__inner">
      <header class="home-services__head">
        <p class="label home-services__eyebrow" data-reveal>
          <span class="home-services__bar"></span>What we build
        </p>
        <h2 class="text-section" data-reveal>
          Six&nbsp;commercial sectors.<br />
          One&nbsp;trade discipline.
        </h2>
        <p class="home-services__lead" data-reveal>
          Drywall &amp; metal-stud framing across every commercial interior our
          clients build — and every scope inside those walls.
        </p>
      </header>

      <div class="home-services__grid">
        {services.map((s) => <ServiceCard service={s} />)}
      </div>
    </div>
  </section>

  <!-- =============== F E A T U R E D &nbsp; P R O J E C T S =============== -->
  <section class="home-projects">
    <div class="home-projects__inner">
      <header class="home-projects__head">
        <p class="label home-projects__eyebrow" data-reveal>
          <span class="home-services__bar"></span>Selected projects
        </p>
        <h2 class="text-section" data-reveal>
          We <em>frame</em> what other people walk into.
        </h2>
        <a href="/projects/" class="home-projects__all" data-reveal>
          All projects
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" />
          </svg>
        </a>
      </header>

      <div class="home-projects__grid">
        {featured.map((p, i) => <ProjectCard project={p} feature={i === 0} />)}
      </div>
    </div>
  </section>

  <!-- =============== A P P R O A C H =============== -->
  <section class="home-approach">
    <div class="home-approach__inner">
      <div class="home-approach__copy">
        <p class="label" data-reveal>
          <span class="home-services__bar"></span>The approach
        </p>
        <h2 class="text-section" data-reveal>
          A trade partner, not a&nbsp;sales pitch.
        </h2>
        <p data-reveal>
          We don't sell dreams. We coordinate with the general contractor, work
          to the drawings, and finish ready for inspection. The plates are
          plumb, the studs are on layout, the drywall is clean, and the schedule
          you signed is the schedule we hit.
        </p>
        <p data-reveal>
          Experienced crews, proven field leadership, and a strict QC and safety
          program — the quiet, dependable craft that keeps a commercial build
          on track.
        </p>
        <ul class="home-approach__list" data-reveal>
          <li><span class="label">01</span> Square. Plumb. On layout.</li>
          <li><span class="label">02</span> Coordinated with every trade.</li>
          <li><span class="label">03</span> Inspection-ready finish.</li>
          <li><span class="label">04</span> Phased around your operations.</li>
        </ul>
      </div>

      <div class="home-approach__visual" data-reveal>
        <img
          src="/images/projects/jobsite-05.webp"
          srcset="/images/projects/jobsite-05-800.webp 800w, /images/projects/jobsite-05.webp 1600w"
          sizes="(min-width: 980px) 45vw, 100vw"
          width="1600"
          height="1067"
          alt="A commercial Nirvana Construction job site nearing completion."
          loading="lazy"
        />
        <div class="home-approach__corner" aria-hidden="true">
          <span class="label">Jobsite · MD</span>
          <span class="label">3:2 · graded</span>
        </div>
      </div>
    </div>
  </section>

  <!-- =============== S C O P E =============== -->
  <section class="home-scope">
    <div class="home-scope__inner">
      <Reveal class="home-scope__intro">
        <p class="label">
          <span class="home-services__bar"></span>Scope of work
        </p>
        <h2 class="text-section">
          Every wall in&nbsp;the&nbsp;building.
        </h2>
      </Reveal>
      <ul class="home-scope__list">
        {scopeOfWork.map((item, i) => (
          <li class="home-scope__row" data-reveal style={`transition-delay:${i * 60}ms`}>
            <span class="label home-scope__idx">{String(i + 1).padStart(2, "0")}</span>
            <span class="home-scope__name">{item}</span>
            <span class="home-scope__dash" aria-hidden="true"></span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CTASection title="Have a project on the boards? Let's frame it." />
</BaseLayout>

<style>
  /* ============ HERO ============ */
  .home-hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    background: var(--color-ink);
    isolation: isolate;
  }
  .home-hero__poster,
  .home-hero__canvas,
  .home-hero__veil {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .home-hero__poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(1.08) saturate(0.85) contrast(0.95);
    transform: scale(1.04);
    opacity: 0.35;     /* the photo is just atmosphere behind the 3D + text */
    mix-blend-mode: multiply;
  }
  .home-hero__canvas { z-index: 1; }
  .home-hero__veil {
    z-index: 2;
    background:
      radial-gradient(ellipse 80% 90% at 5% 60%, var(--color-ink) 0%, color-mix(in oklab, var(--color-ink) 70%, transparent) 35%, transparent 65%),
      linear-gradient(180deg, color-mix(in oklab, var(--color-ink) 60%, transparent) 0%, transparent 25%, transparent 65%, color-mix(in oklab, var(--color-ink) 70%, transparent) 100%);
    pointer-events: none;
  }

  .home-hero__inner {
    position: relative;
    z-index: 3;
    min-height: 100vh;
    max-width: 96rem;
    margin: 0 auto;
    padding: 7.5rem clamp(1.25rem, 4vw, 3.5rem) 2.5rem;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 2.25rem;
  }

  .home-hero__topbar {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .home-hero__cert {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-bone);
  }
  .home-hero__dot {
    width: 0.5rem;
    height: 0.5rem;
    background: var(--color-emerald);
    border-radius: 999px;
    box-shadow: 0 0 0 4px color-mix(in oklab, var(--color-emerald) 20%, transparent);
    animation: cert-pulse 2s ease-in-out infinite;
  }
  @keyframes cert-pulse {
    0%, 100% { box-shadow: 0 0 0 4px color-mix(in oklab, var(--color-emerald) 20%, transparent); }
    50% { box-shadow: 0 0 0 8px color-mix(in oklab, var(--color-emerald) 10%, transparent); }
  }
  .home-hero__coord {
    text-align: right;
    color: var(--color-concrete);
    line-height: 1.5;
  }

  .home-hero__copy {
    align-self: end;
    max-width: 64rem;
  }
  .home-hero__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.85rem, 9.5vw, 9.5rem);
    line-height: 0.92;
    letter-spacing: -0.035em;
    text-wrap: balance;
    margin-bottom: 2rem;
  }
  .home-hero__line {
    display: block;
    opacity: 0;
    transform: translateY(60px);
    animation: hero-rise 1.1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--d, 0ms);
  }
  @keyframes hero-rise {
    to { opacity: 1; transform: none; }
  }
  .home-hero__line--em { color: var(--color-flare); }
  .home-hero__line--stroke {
    -webkit-text-stroke: 1.4px var(--color-emerald);
    color: transparent;
  }

  .home-hero__lead {
    max-width: 42rem;
    color: var(--color-ash);
    font-size: 1.05rem;
    line-height: 1.65;
  }
  .home-hero__ctas {
    margin-top: 2.2rem;
    display: flex;
    gap: 1.2rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .home-hero__primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    padding: 1rem 1.5rem;
    background: var(--color-flare);
    color: var(--color-ink);
    font-weight: 600;
    overflow: hidden;
    isolation: isolate;
  }
  .home-hero__primary svg {
    width: 1rem;
    height: 1rem;
    transition: transform 0.4s var(--ease-out-expo);
  }
  .home-hero__primary::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--color-bone);
    transform: translateY(101%);
    transition: transform 0.5s var(--ease-out-expo);
    z-index: -1;
  }
  .home-hero__primary:hover::before { transform: translateY(0); }
  .home-hero__primary:hover svg { transform: translate(3px, -3px); }
  .home-hero__secondary {
    color: var(--color-bone);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-flare);
    transition: color 0.3s;
  }
  .home-hero__secondary:hover { color: var(--color-flare); }

  .home-hero__bottombar {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .home-hero__strip {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .home-hero__strip .label { color: var(--color-concrete); }
  .home-hero__strip b {
    color: var(--color-bone);
    font-weight: 500;
    margin-left: 0.25rem;
  }
  .home-hero__scroll {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-concrete);
  }
  .home-hero__scroll-line {
    display: inline-block;
    width: 3rem;
    height: 1px;
    background: linear-gradient(90deg, var(--color-concrete), transparent);
    animation: scroll-arrow 2.2s ease-in-out infinite;
  }
  @keyframes scroll-arrow {
    0%, 100% { transform: translateX(0); opacity: 1; }
    50% { transform: translateX(0.5rem); opacity: 0.4; }
  }
  @media (prefers-reduced-motion: reduce) {
    .home-hero__line { animation: none; opacity: 1; transform: none; }
    .home-hero__dot { animation: none; }
    .home-hero__scroll-line { animation: none; }
  }

  /* ============ SERVICES ============ */
  .home-services {
    padding: clamp(4.5rem, 10vw, 9rem) clamp(1.25rem, 4vw, 3.5rem) clamp(3rem, 6vw, 5rem);
  }
  .home-services__inner { max-width: 96rem; margin: 0 auto; }
  .home-services__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 3.5rem;
  }
  .home-services__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-emerald);
  }
  .home-services__bar {
    width: 1.5rem;
    height: 1px;
    background: var(--color-emerald);
  }
  .home-services__lead {
    color: var(--color-ash);
    font-size: 1.05rem;
    max-width: 36rem;
  }
  .home-services__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 700px) { .home-services__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1080px) {
    .home-services__head { grid-template-columns: 1.2fr 1fr; align-items: end; }
    .home-services__grid { grid-template-columns: repeat(3, 1fr); }
  }

  /* ============ PROJECTS ============ */
  .home-projects {
    padding: clamp(3rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3.5rem);
    background:
      linear-gradient(180deg, var(--color-ink) 0%, var(--color-graphite) 100%);
  }
  .home-projects__inner { max-width: 96rem; margin: 0 auto; }
  .home-projects__head {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }
  .home-projects__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-flare);
  }
  .home-projects__head h2 :global(em) { color: var(--color-flare); font-style: normal; }
  .home-projects__all {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.06em;
    color: var(--color-bone);
    align-self: end;
    border-bottom: 1px solid var(--color-flare);
    padding-bottom: 0.4rem;
    width: fit-content;
    transition: gap 0.3s, color 0.3s;
  }
  .home-projects__all svg { width: 0.95rem; height: 0.95rem; color: var(--color-flare); }
  .home-projects__all:hover { gap: 0.8rem; }
  .home-projects__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 700px) { .home-projects__grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1080px) {
    .home-projects__head { grid-template-columns: 1.2fr 1fr; align-items: end; }
    .home-projects__grid {
      grid-template-columns: repeat(6, 1fr);
    }
    .home-projects__grid > :global(*:nth-child(1)) { grid-column: span 6; }
    .home-projects__grid > :global(*:nth-child(2)),
    .home-projects__grid > :global(*:nth-child(3)),
    .home-projects__grid > :global(*:nth-child(4)) { grid-column: span 2; }
  }

  /* ============ APPROACH ============ */
  .home-approach {
    padding: clamp(5rem, 10vw, 9rem) clamp(1.25rem, 4vw, 3.5rem);
    background: var(--color-graphite);
  }
  .home-approach__inner {
    max-width: 96rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .home-approach__copy p { color: var(--color-ash); margin-top: 1.25rem; max-width: 32rem; line-height: 1.65; }
  .home-approach__copy h2 { margin-top: 1.25rem; }
  .home-approach__list {
    margin-top: 2.5rem;
    display: grid;
    gap: 0.85rem;
  }
  .home-approach__list li {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    color: var(--color-bone);
    font-size: 1.05rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid color-mix(in oklab, var(--color-bone) 9%, transparent);
  }
  .home-approach__list .label { color: var(--color-emerald); }

  .home-approach__visual { position: relative; aspect-ratio: 4 / 3; overflow: hidden; }
  .home-approach__visual img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 1.4s var(--ease-out-expo);
  }
  .home-approach__visual:hover img { transform: scale(1.05); }
  .home-approach__corner {
    position: absolute;
    inset: auto 1rem 1rem 1rem;
    display: flex;
    justify-content: space-between;
    color: var(--color-bone);
    padding: 0.6rem 0.8rem;
    background: color-mix(in oklab, var(--color-ink) 70%, transparent);
    backdrop-filter: blur(8px);
  }
  @media (min-width: 980px) {
    .home-approach__inner { grid-template-columns: 1fr 1.05fr; align-items: center; gap: 5rem; }
  }

  /* ============ SCOPE ============ */
  .home-scope {
    padding: clamp(5rem, 10vw, 9rem) clamp(1.25rem, 4vw, 3.5rem);
  }
  .home-scope__inner {
    max-width: 96rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  .home-scope__intro { display: grid; gap: 1.25rem; align-content: start; }
  .home-scope__intro :global(.label) {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    color: var(--color-flare);
  }
  .home-scope__list { display: grid; gap: 0; }
  .home-scope__row {
    display: grid;
    grid-template-columns: 4ch 1fr auto;
    align-items: baseline;
    gap: 1.5rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid color-mix(in oklab, var(--color-bone) 9%, transparent);
    transition: padding-left 0.4s var(--ease-out-expo), color 0.3s;
  }
  .home-scope__row:hover { padding-left: 1rem; color: var(--color-flare); }
  .home-scope__idx { color: var(--color-concrete); }
  .home-scope__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.4rem, 3vw, 2.5rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
  }
  .home-scope__dash {
    width: 3rem;
    height: 1px;
    background: color-mix(in oklab, var(--color-bone) 25%, transparent);
    transition: width 0.4s var(--ease-out-expo), background-color 0.3s;
  }
  .home-scope__row:hover .home-scope__dash {
    width: 5rem;
    background: var(--color-flare);
  }
  @media (min-width: 980px) {
    .home-scope__inner { grid-template-columns: 0.7fr 1.3fr; gap: 5rem; }
  }
</style>
